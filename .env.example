# TerraVault Environment Configuration
# Copy this file to .env and fill in the values
#
# ⚠️  WARNING: Never use default passwords in production!
# ⚠️  Use secrets management (AWS Secrets Manager, HashiCorp Vault, etc.)
# ⚠️  All passwords below MUST be changed before deployment!

# ========================================
# API Configuration
# ========================================
# API server host and port
TERRAVAULT_API_HOST=0.0.0.0
TERRAVAULT_API_PORT=8000

# API Key Hash (REQUIRED)
# Generate using: python scripts/generate_api_key.py
# This should be a bcrypt hash of your API key (60 characters)
#
# ⚠️  CRITICAL: DO NOT use 'source .env' or '. .env' in shell scripts!
#     Shell sourcing will expand $2b$12$... as variables, breaking the hash.
#     Let python-dotenv load this file instead.
TERRAVAULT_API_KEY_HASH=your-bcrypt-hash-here

# CORS origins (comma-separated)
TERRAVAULT_API_CORS_ORIGINS=http://localhost:3000

# ========================================
# Database Configuration
# ========================================
# PostgreSQL connection URL (optional, for future use)
# Format: postgresql+asyncpg://user:password@host:port/database
TERRAVAULT_DATABASE_URL=postgresql+asyncpg://terravault_user:CHANGE_ME_IN_PRODUCTION@localhost:5432/terravault
TERRAVAULT_DATABASE_POOL_SIZE=10

# PostgreSQL password (for Docker Compose)
POSTGRES_PASSWORD=CHANGE_ME_IN_PRODUCTION

# ========================================
# Redis Configuration
# ========================================
# Redis connection URL for caching and rate limiting
TERRAVAULT_REDIS_URL=redis://localhost:6379
TERRAVAULT_REDIS_MAX_CONNECTIONS=50

# ========================================
# Cache Configuration
# ========================================
# Cache TTL in seconds
TERRAVAULT_CACHE_TTL_SECONDS=3600
# Maximum number of cache entries
TERRAVAULT_CACHE_MAX_ENTRIES=100

# ========================================
# ML Model Configuration
# ========================================
# Minimum confidence threshold for vulnerability detection (0.0 - 1.0)
TERRAVAULT_MODEL_CONFIDENCE_THRESHOLD=0.7
# ML model version
TERRAVAULT_MODEL_VERSION=1.0.0
# Path to ML model file
TERRAVAULT_MODEL_PATH=models/terravault_model.pkl

# ========================================
# Security Configuration
# ========================================
# Maximum allowed file size in megabytes
TERRAVAULT_MAX_FILE_SIZE_MB=10
# Maximum time allowed for a single scan in seconds
TERRAVAULT_SCAN_TIMEOUT_SECONDS=30

# Rate limiting
TERRAVAULT_RATE_LIMIT_REQUESTS=100
TERRAVAULT_RATE_LIMIT_WINDOW_SECONDS=60

# ========================================
# Logging Configuration
# ========================================
# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
TERRAVAULT_LOG_LEVEL=INFO
# Log format: json or text
TERRAVAULT_LOG_FORMAT=json
# Optional log file path
TERRAVAULT_LOG_FILE=

# ========================================
# Environment
# ========================================
# Environment: development, staging, production
TERRAVAULT_ENVIRONMENT=development
# Enable debug mode (true/false)
TERRAVAULT_DEBUG=false

# ========================================
# Monitoring Configuration
# ========================================
# Grafana admin password
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_IN_PRODUCTION
