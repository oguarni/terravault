# Claude Code Ignore File

# Version control
.git/

# Python bytecode
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/

# Testing & coverage
.pytest_cache/
htmlcov/
.coverage
.benchmarks/

# ML models (binary files)
models/*.pkl
models/*.joblib

# Type checking cache
.mypy_cache/

# Build artifacts
*.egg-info/

# Generated scan artifacts
scan_results/
scan_results_*.json
scan_history.json
bandit-report.json

# Documentation & screenshots
docs/
screenshots/

# Environment & config
.env
config/production.yaml
config/local.yaml

# Logs
*.log
