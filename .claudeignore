# Claude Code Ignore File

# Version control
.git/

# Python bytecode
*.pyc
__pycache__/

# Virtual environments
venv/
.venv/

# Testing & coverage
.pytest_cache/
htmlcov/
.coverage
.benchmarks/

# ML models (binary files)
models/*.pkl
models/*.joblib
models/*.npy
models/*.json
models/versions/

# Type checking cache
.mypy_cache/

# Build artifacts
*.egg-info/

# Generated scan artifacts
scan_results/
scan_results_*.json
scan_history.json
bandit.json
bandit-report.json

# Quality Gate / Ratchet generated reports
gate-report.md
gate-report-after-fix.md
pylint-output.json
pylint-report.txt
ratchet-current.json

# Stale / legacy ghost directory from terravault → terrasafe rename
terravault/

# Architecture / diagram binary assets
terrasafe-architecture.svg

# Documentation, screenshots & assets
docs/
screenshots/
imgs/

# Editor
.vscode/

# Environment & config
.env
.env.*
config/production.yaml
config/local.yaml

# Security reports
*.sarif
safety-report.txt
trivy-report.json
sbom.json
sbom.xml
gitleaks-report.*
.secrets.baseline

# Private keys & certificates
*.pem
*.key
*.p12
*.pfx

# Build artifacts
build/
dist/

# Coverage
coverage.xml

# Logs
*.log
